# ===========================================
# LJ MCP Server - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Shopify
SHOPIFY_STORE_URL=larsson-jennings.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Shopify OAuth credentials — used to auto-refresh SHOPIFY_ACCESS_TOKEN on expiry.
# The new token is logged to stdout when a refresh occurs; update SHOPIFY_ACCESS_TOKEN
# in your deployment env to persist it across restarts.
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Triple Whale
TRIPLE_WHALE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Klaviyo
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000
NODE_ENV=production
